---
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  prev: CollectionEntry<'posts'> | null;
  next: CollectionEntry<'posts'> | null;
}

const { post, prev, next } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
---

<article class="post container container-narrow">
  <header class="post-header">
    <a href={import.meta.env.BASE_URL} class="back-link">← 返回文章列表</a>
    <h1 class="post-title">{title}</h1>
    <p class="post-desc">{description}</p>
    <div class="post-meta">
      <FormattedDate date={pubDate} />
      {
        updatedDate && (
          <span class="updated">
            （更新于 <FormattedDate date={updatedDate} />）
          </span>
        )
      }
    </div>
    <TagList tags={tags} class="post-tags" />
  </header>

  <div class="prose">
    <slot />
  </div>

  <footer class="post-footer">
    <TagList tags={tags} class="post-tags" />
    <nav class="post-nav" aria-label="文章导航">
      <div class="nav-col">
        {
          prev && (
            <a class="nav-link" href={`${import.meta.env.BASE_URL}posts/${prev.id}`}>
              <span class="nav-dir">← 上一篇</span>
              <span class="nav-title">{prev.data.title}</span>
            </a>
          )
        }
      </div>
      <div class="nav-col nav-col-end">
        {
          next && (
            <a class="nav-link nav-link-end" href={`${import.meta.env.BASE_URL}posts/${next.id}`}>
              <span class="nav-dir">下一篇 →</span>
              <span class="nav-title">{next.data.title}</span>
            </a>
          )
        }
      </div>
    </nav>
  </footer>
</article>

<style>
  .post {
    display: block;
  }
  .post-header {
    margin-bottom: var(--space-6);
  }
  .back-link {
    display: inline-block;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .back-link:hover {
    color: var(--color-primary);
  }
  .post-title {
    font-size: 2.1rem;
    margin: 0 0 var(--space-3);
  }
  .post-desc {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin: 0 0 var(--space-4);
  }
  .post-meta {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    margin-bottom: var(--space-3);
  }
  .updated {
    margin-left: 4px;
  }
  .post-tags {
    margin-top: var(--space-2);
  }
  .post-footer {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }
  .nav-col-end {
    text-align: right;
  }
  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition);
  }
  .nav-link:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-soft);
  }
  .nav-dir {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .nav-title {
    font-weight: 600;
    color: var(--color-text);
  }
  .nav-link-end {
    align-items: flex-end;
  }
  @media (max-width: 640px) {
    .post-title {
      font-size: 1.6rem;
    }
    .post-nav {
      grid-template-columns: 1fr;
    }
    .nav-col-end {
      text-align: left;
    }
    .nav-link-end {
      align-items: flex-start;
    }
  }
</style>
