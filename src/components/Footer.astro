---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-copy">© {year} ResumeBlog · 用 Astro 构建</p>
    <nav class="footer-links">
      <a href={import.meta.env.BASE_URL}>首页</a>
      <a href={`${import.meta.env.BASE_URL}about`}>关于我</a>
      <a href={`${import.meta.env.BASE_URL}projects`}>项目</a>
      <a href={`${import.meta.env.BASE_URL}posts`}>博客</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-subtle);
    padding: var(--space-5) 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .footer-copy {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .footer-links {
    display: flex;
    gap: var(--space-4);
    font-size: 0.9rem;
  }
  .footer-links a {
    color: var(--color-text-muted);
  }
  .footer-links a:hover {
    color: var(--color-primary);
  }
  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
