---
import { profile } from '../data/profile';

const sectionTitle = (text: string) => text;
---

<section class="resume-section" id="certificates" data-reveal>
  <h2 class="section-title">{sectionTitle('证书与荣誉')}</h2>
  <ul class="cert-list">
    {
      profile.certificates.map((c) => (
        <li class="cert-item card card-glow">
          <div class="cert-main">
            <span class="cert-name">{c.name}</span>
            <span class="cert-issuer">{c.issuer}</span>
          </div>
          <span class="cert-date">{c.date}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .cert-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  .cert-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
  }
  .cert-main {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cert-name {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .cert-issuer {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }
  .cert-date {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-primary);
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .cert-list {
      grid-template-columns: 1fr;
    }
  }
</style>
