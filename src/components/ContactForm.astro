---
interface Props {
  email: string;
}
const { email } = Astro.props;
---

<form class="contact-form card" id="contact-form" data-email={email} novalidate>
  <div class="form-row">
    <div class="field">
      <label for="cf-name">称呼</label>
      <input id="cf-name" name="name" type="text" placeholder="您的姓名" autocomplete="name" required />
      <span class="err" data-err="name"></span>
    </div>
    <div class="field">
      <label for="cf-email">邮箱</label>
      <input id="cf-email" name="email" type="email" placeholder="you@example.com" autocomplete="email" required />
      <span class="err" data-err="email"></span>
    </div>
  </div>
  <div class="field">
    <label for="cf-message">留言</label>
    <textarea id="cf-message" name="message" rows="4" placeholder="想聊聊合作、研究或其它想法……" required></textarea>
    <span class="err" data-err="message"></span>
  </div>
  <button type="submit" class="btn btn-primary form-submit">
    <span class="submit-text">发送留言</span>
    <svg class="submit-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" /></svg>
  </button>

  <div class="form-success" data-success hidden>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>
    <span>已为你打开邮件客户端，如未弹出可直接发送至 <a href={`mailto:${email}`}>{email}</a></span>
  </div>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-soft);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 11px 14px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color var(--transition), box-shadow var(--transition),
      background-color var(--transition);
  }
  .field textarea {
    resize: vertical;
    min-height: 96px;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: var(--color-bg-elevated);
    box-shadow: 0 0 0 4px var(--color-primary-soft);
  }
  .field.invalid input,
  .field.invalid textarea {
    border-color: var(--color-accent);
  }
  .err {
    font-size: 0.78rem;
    color: var(--color-accent);
    min-height: 0;
  }
  .form-submit {
    align-self: flex-start;
  }
  .submit-icon {
    transition: transform var(--transition);
  }
  .form-submit:hover .submit-icon {
    transform: translateX(3px) rotate(8deg);
  }
  .form-success {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-size: 0.9rem;
    animation: fadeInUp 0.5s var(--ease-spring);
  }
  .form-success svg {
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const email = form.dataset.email || '';
    const success = form.querySelector('[data-success]') as HTMLElement | null;
    const setErr = (name: string, msg: string) => {
      const field = form.querySelector(`[name="${name}"]`)?.closest('.field');
      const errEl = form.querySelector(`[data-err="${name}"]`);
      if (field) field.classList.toggle('invalid', !!msg);
      if (errEl) errEl.textContent = msg;
    };
    const isEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = String(data.get('name') || '').trim();
      const mail = String(data.get('email') || '').trim();
      const message = String(data.get('message') || '').trim();
      let ok = true;

      if (!name) {
        setErr('name', '请填写称呼');
        ok = false;
      } else setErr('name', '');
      if (!mail || !isEmail(mail)) {
        setErr('email', '请填写有效的邮箱');
        ok = false;
      } else setErr('email', '');
      if (!message) {
        setErr('message', '请写点什么吧');
        ok = false;
      } else setErr('message', '');

      if (!ok) return;

      // 静态站点无后端：通过 mailto 直连邮件客户端。
      // 如需服务端收集，可将下方替换为向 Formspree / 自建接口的 fetch POST。
      const subject = encodeURIComponent(`来自 ${name} 的网站留言`);
      const body = encodeURIComponent(`${message}\n\n—— ${name}（${mail}）`);
      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;

      if (success) success.hidden = false;
      form.querySelectorAll('input, textarea').forEach((el) => {
        (el as HTMLInputElement).value = '';
      });
    });
  }
</script>
