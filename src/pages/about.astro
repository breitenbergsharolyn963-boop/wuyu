---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import Sidebar from '../components/Sidebar.astro';
import StatsHero from '../components/StatsHero.astro';
import Certificates from '../components/Certificates.astro';
import SkillsRadar from '../components/SkillsRadar.astro';
import { profile } from '../data/profile';

const sectionTitle = (text: string) => text;
const emailContact = profile.contacts.find((c) => c.href?.startsWith('mailto:'));
const email = emailContact?.href?.replace('mailto:', '') || 'contact@example.com';
---

<BaseLayout title="关于" description={`${profile.name} 的个人简历`}>
  <div class="container resume-layout">
    <Sidebar />

    <div class="main-col">
      <StatsHero />

      <!-- 教育背景 -->
      <section class="resume-section" data-reveal>
        <h2 class="section-title">{sectionTitle('教育背景')}</h2>
        <div class="timeline">
          {
            profile.education.map((e) => (
              <div class="timeline-item">
                <div class="timeline-head">
                  <span class="timeline-title">{e.school}</span>
                  <span class="timeline-period">{e.period}</span>
                </div>
                <p class="timeline-sub">{e.degree}</p>
                {e.detail && <p class="timeline-detail">{e.detail}</p>}
              </div>
            ))
          }
        </div>
      </section>

      <!-- 科研经历 -->
      <section class="resume-section" data-reveal>
        <h2 class="section-title">{sectionTitle('科研经历')}</h2>
        <div class="timeline">
          {
            profile.experience.map((x) => (
              <div class="timeline-item">
                <div class="timeline-head">
                  <span class="timeline-title">
                    {x.company}
                    <span class="timeline-role">· {x.role}</span>
                  </span>
                  <span class="timeline-period">{x.period}</span>
                </div>
                {x.location && <p class="timeline-sub">{x.location}</p>}
                <ul class="timeline-list">
                  {x.highlights.map((h) => <li>{h}</li>)}
                </ul>
                {
                  x.related && x.related.length > 0 && (
                    <div class="timeline-related">
                      <span class="tr-label">相关</span>
                      {x.related.map((r) => (
                        <a
                          class="tr-link"
                          href={`${import.meta.env.BASE_URL}${r.type === 'post' ? 'posts' : 'projects'}/${r.id}`}
                        >
                          <span class="tr-type">{r.type === 'post' ? '文章' : '项目'}</span>
                          <span class="tr-text">{r.label}</span>
                        </a>
                      ))}
                    </div>
                  )
                }
              </div>
            ))
          }
        </div>
      </section>

      <!-- 技能熟练度（动画技能条） -->
      <section class="resume-section" data-reveal>
        <h2 class="section-title">{sectionTitle('技能熟练度')}</h2>
        <div class="skill-bars card">
          {
            profile.coreSkills.map((s, i) => (
              <div class="skill-bar-row" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
                <div class="skill-bar-head">
                  <span class="skill-bar-name">{s.name}</span>
                  <span class="skill-bar-pct">{s.level}%</span>
                </div>
                <div class="skill-bar-track">
                  <span class="skill-bar-fill" style={`--level:${s.level}%`} />
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 技能列表 -->
      <section class="resume-section" data-reveal>
        <h2 class="section-title">{sectionTitle('技能列表')}</h2>
        <div class="skills-grid">
          {
            profile.skills.map((g) => (
              <div class="skill-group card card-glow">
                <h3 class="skill-cat">{g.category}</h3>
                <div class="tag-list">
                  {g.items.map((s) => <span class="tag">{s}</span>)}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 能力雷达 -->
      <section class="resume-section" data-reveal>
        <h2 class="section-title">{sectionTitle('能力雷达')}</h2>
        <div class="radar-card card">
          <SkillsRadar />
        </div>
      </section>

      <!-- 项目经验 -->
      <section class="resume-section" data-reveal>
        <h2 class="section-title">{sectionTitle('项目经验')}</h2>
        <div class="projects">
          {
            profile.projects.map((p, i) => (
              <article class="project card card-glow" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
                <div class="timeline-head">
                  <span class="timeline-title">
                    {p.link ? (
                      <a href={p.link} target="_blank" rel="noopener">
                        {p.name}
                      </a>
                    ) : (
                      p.name
                    )}
                    <span class="timeline-role">· {p.role}</span>
                  </span>
                  <span class="timeline-period">{p.period}</span>
                </div>
                <p class="project-desc">{p.description}</p>
                <div class="tag-list">
                  {p.tech.map((t) => <span class="tag">{t}</span>)}
                </div>
                <a class="proj-more" href={`${import.meta.env.BASE_URL}projects/${p.slug}`}>查看案例 →</a>
              </article>
            ))
          }
        </div>
      </section>

      <Certificates />

      <!-- 联系我 -->
      <section class="resume-section" id="contact" data-reveal>
        <h2 class="section-title">{sectionTitle('联系我')}</h2>
        <p class="contact-intro">
          对研究合作、学术交流或项目机会感兴趣？欢迎填写下方表单，或直接发送邮件。
        </p>
        <ContactForm email={email} />
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .resume-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--space-7);
    align-items: start;
    max-width: 1180px;
    margin: 0 auto;
    padding-top: var(--space-7);
    padding-bottom: var(--space-9);
  }
  .main-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    min-width: 0;
    counter-reset: sec;
  }

  .resume-section {
    scroll-margin-top: 88px;
  }
  .section-title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 1.35rem;
    margin: 0 0 var(--space-4);
  }
  .section-title::before {
    content: '';
    width: 4px;
    height: 1.2em;
    border-radius: 2px;
    background: var(--color-primary);
  }
  .resume-section {
    counter-increment: sec;
  }
  .section-title::after {
    content: '0' counter(sec);
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    opacity: 0.5;
  }

  .timeline {
    position: relative;
    padding-left: 28px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(
      180deg,
      var(--color-primary),
      color-mix(in srgb, var(--color-primary) 25%, transparent)
    );
  }
  .timeline-item {
    position: relative;
    padding: 0 0 var(--space-5);
  }
  .timeline-item:last-child {
    padding-bottom: 0;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -27px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 0 4px var(--color-bg);
  }
  .timeline-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .timeline-title {
    font-weight: 700;
    font-size: 1.05rem;
  }
  .timeline-role {
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.92rem;
  }
  .timeline-period {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }
  .timeline-sub {
    margin: 4px 0 0;
    color: var(--color-text-soft);
  }
  .timeline-detail {
    margin: 4px 0 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .timeline-list {
    margin: var(--space-3) 0 0;
    padding-left: 1.2em;
    color: var(--color-text-soft);
  }
  .timeline-list li {
    margin-bottom: 6px;
  }
  .timeline-related {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-top: var(--space-3);
  }
  .tr-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }
  .tr-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    text-decoration: none;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    color: var(--color-text-soft);
    transition: all var(--transition);
  }
  .tr-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-1px);
  }
  .tr-type {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  .skill-group {
    padding: var(--space-4);
  }
  .skill-cat {
    margin: 0 0 var(--space-3);
    font-size: 1rem;
  }

  /* 动画技能条 */
  .skill-bars {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
  }
  .skill-bar-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }
  .skill-bar-name {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .skill-bar-pct {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-primary);
    font-weight: 700;
  }
  .skill-bar-track {
    height: 9px;
    border-radius: var(--radius-full);
    background: var(--color-bg-subtle);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .skill-bar-fill {
    display: block;
    height: 100%;
    width: 0;
    border-radius: var(--radius-full);
    background: var(--gradient-primary);
    background-size: 200% 100%;
    transition: width 1.3s var(--transition-slow);
  }
  .skill-bar-row.revealed .skill-bar-fill {
    width: var(--level);
    animation: gradientShift 4s ease infinite;
  }

  /* 联系区 */
  .contact-intro {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
  }

  .projects {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .project-desc {
    margin: var(--space-2) 0 var(--space-3);
    color: var(--color-text-soft);
  }
  .radar-card {
    display: flex;
    justify-content: center;
    padding: var(--space-5);
  }
  .proj-more {
    display: inline-block;
    margin-top: var(--space-3);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }
  .proj-more:hover {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .resume-layout {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
