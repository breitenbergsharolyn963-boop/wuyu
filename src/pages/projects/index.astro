---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { profile } from '../../data/profile';

const base = import.meta.env.BASE_URL;
const projects = profile.projects;
const allTags = [...new Set(projects.flatMap((p) => p.tech))];
---

<BaseLayout title="项目" description="研究项目与工程实践案例 —— 离散元仿真、敏感性分析与高通量数据处理">
  <div class="container project-index">
    <header class="pi-head" data-reveal>
      <span class="eyebrow">Projects</span>
      <h1 class="pi-title">项目与案例</h1>
      <p class="pi-sub">从超细粉体离散元仿真到高通量数据处理的完整研究实践</p>
    </header>

    <div class="pi-filter" role="group" aria-label="按技术筛选">
      <button class="pi-chip is-active" type="button" data-filter="all">全部</button>
      {
        allTags.map((t) => (
          <button class="pi-chip" type="button" data-filter={t}>{t}</button>
        ))
      }
    </div>

    <div class="pi-grid">
      {
        projects.map((p, i) => (
          <a
            class="pi-card card card-glow"
            href={`${base}projects/${p.slug}`}
            data-reveal
            data-tags={p.tech.join(' ')}
            style={`--reveal-delay:${i * 0.08}s`}
          >
            <div class="pi-card-top">
              <span class="pi-role">{p.role}</span>
              <span class="pi-period">{p.period}</span>
            </div>
            <h2 class="pi-name">{p.name}</h2>
            <p class="pi-desc">{p.description}</p>
            <div class="tag-list">
              {p.tech.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
            <span class="pi-more">查看案例 →</span>
          </a>
        ))
      }
    </div>
    <p class="pi-empty" hidden>没有匹配的项目，试试其他标签。</p>
  </div>

  <script>
    const filterBar = document.querySelector('.pi-filter');
    const cards = [...document.querySelectorAll('.pi-card')];
    const empty = document.querySelector('.pi-empty');
    if (filterBar) {
      filterBar.addEventListener('click', (e) => {
        const btn = e.target.closest('.pi-chip');
        if (!btn) return;
        const f = btn.dataset.filter;
        filterBar.querySelectorAll('.pi-chip').forEach((c) => c.classList.toggle('is-active', c === btn));
        let visible = 0;
        cards.forEach((card) => {
          const tags = (card.dataset.tags || '').split(' ');
          const show = f === 'all' || tags.includes(f);
          card.hidden = !show;
          if (show) visible++;
        });
        if (empty) empty.hidden = visible > 0;
      });
    }
  </script>
</BaseLayout>

<style>
  .project-index {
    max-width: 1000px;
    margin: 0 auto;
    padding-top: var(--space-7);
    padding-bottom: var(--space-9);
  }
  .pi-head {
    margin-bottom: var(--space-6);
  }
  .eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: var(--space-2);
  }
  .pi-title {
    font-size: 2.4rem;
    margin: 0 0 var(--space-3);
  }
  .pi-sub {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin: 0;
  }
  .pi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }
  .pi-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition);
  }
  .pi-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .pi-role {
    color: var(--color-primary);
    font-weight: 600;
  }
  .pi-name {
    font-size: 1.25rem;
    margin: 0;
    line-height: 1.35;
  }
  .pi-desc {
    color: var(--color-text-soft);
    font-size: 0.95rem;
    margin: 0;
    flex: 1;
  }
  .pi-more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: var(--space-2);
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    font-size: 0.78rem;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  @media (max-width: 720px) {
    .pi-grid {
      grid-template-columns: 1fr;
    }
    .pi-title {
      font-size: 1.9rem;
    }
  }
  .pi-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: var(--space-5);
  }
  .pi-chip {
    font: inherit;
    font-size: 0.85rem;
    padding: 8px 16px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition);
  }
  .pi-chip:hover {
    color: var(--color-text);
    border-color: var(--color-primary);
  }
  .pi-chip.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
    font-weight: 600;
  }
  .pi-empty {
    color: var(--color-text-muted);
    padding: var(--space-5) 0;
    text-align: center;
  }
</style>
