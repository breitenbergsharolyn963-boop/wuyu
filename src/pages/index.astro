---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';

const ringRadius = 40;
const ringCircum = 2 * Math.PI * ringRadius;
const topSkills = profile.coreSkills.slice(0, 4);
const base = import.meta.env.BASE_URL;
const nameInitial = profile.name.slice(0, 1);

const ringDefs = [
  { id: 'gradA', from: '#F472B6', to: '#A855F7' },
  { id: 'gradB', from: '#22D3EE', to: '#818CF8' },
  { id: 'gradC', from: '#34D399', to: '#6366F1' },
  { id: 'gradD', from: '#FBBF24', to: '#EC4899' },
];

const rings = topSkills.map((s, i) => {
  const pct = s.level / 100;
  const sweep = pct * 360;
  const largeArc = sweep > 180 ? 1 : 0;
  const endAngle = -Math.PI / 2 + pct * 2 * Math.PI;
  const endX = 50 + ringRadius * Math.cos(endAngle);
  const endY = 50 + ringRadius * Math.sin(endAngle);
  const offset = ringCircum - pct * ringCircum;
  return { ...s, i, largeArc, endX, endY, offset, def: ringDefs[i % ringDefs.length] };
});
---

<BaseLayout title="ResumeBlog" description={`${profile.name} · ${profile.title} —— 个人简历与阶段性研究记录`}>
  <!-- 固定极光背景层（光斑 + 点阵纹理） -->
  <div class="ambient" aria-hidden="true">
    <span class="ambient-blob blob-1"></span>
    <span class="ambient-blob blob-2"></span>
    <span class="ambient-blob blob-3"></span>
    <span class="ambient-blob blob-4"></span>
    <span class="ambient-grid"></span>
  </div>

  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-aurora" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-text" data-reveal>
        <h1 class="hero-name">{profile.name}</h1>
        <p class="hero-title">{profile.title}</p>
        <p class="hero-tagline">{profile.tagline}</p>
        <div class="hero-cta">
          <a href={`${base}about`} class="btn btn-primary">查看完整简历</a>
          <a href={`${base}projects`} class="btn btn-ghost">精选项目</a>
        </div>
      </div>
      <div class="hero-visual" data-reveal style="--reveal-delay:.12s">
        <div class="visual-3d" aria-hidden="true">
          <span>3D</span>
        </div>
        <div class="code-card">
          <pre><code>def dem_simulation(particles):
    return powder_flow + contact_mechanics</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Resume Body ===== -->
  <section class="resume-body">
    <div class="container resume-inner">
      <aside class="sidebar" data-reveal>
        <div class="sidebar-glow" aria-hidden="true"></div>
        <div class="avatar-wrap">
          <div class="avatar-halo" aria-hidden="true"></div>
          <img class="avatar-img" src={`${base}${profile.avatar.replace(/^\//, '')}`} alt={`${profile.name} 头像`} width="96" height="96" loading="eager" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid'; this.previousElementSibling.style.display='none'" />
          <div class="avatar-fallback" aria-hidden="true" style="display:none">{nameInitial}</div>
        </div>
        <h2 class="sidebar-name">{profile.name}</h2>
        <p class="sidebar-title">{profile.title}</p>

        <div class="sidebar-divider"></div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">联系方式</h3>
          <ul class="contact-list">
            {profile.contacts.map(c => (
              <li>
                <span class="contact-label">{c.label}</span>
                {c.href ? (
                  <a href={c.href} class="contact-value">{c.value}</a>
                ) : (
                  <span class="contact-value">{c.value}</span>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">核心技能</h3>
          <div class="skill-rings">
            {rings.map(r => (
              <div class="ring-wrap" data-ring data-level={r.level} style={`--ring-delay:${0.1 * r.i}s`}>
                <svg width="110" height="110" viewBox="0 0 100 100" aria-hidden="true" class="ring-svg">
                  <defs>
                    <linearGradient id={r.def.id} x1="0" y1="0" x2="100" y2="100" gradientUnits="userSpaceOnUse">
                      <stop offset="0%" stop-color={r.def.from} />
                      <stop offset="100%" stop-color={r.def.to} />
                    </linearGradient>
                    <filter id={`glow-${r.def.id}`} x="-50%" y="-50%" width="200%" height="200%">
                      <feGaussianBlur stdDeviation="3" result="blur" />
                      <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                      </feMerge>
                    </filter>
                  </defs>
                  <circle class="ring-track" cx="50" cy="50" r={ringRadius} fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="7" />
                  <circle
                    class="ring-arc"
                    cx="50"
                    cy="50"
                    r={ringRadius}
                    fill="none"
                    stroke={`url(#${r.def.id})`}
                    stroke-width="8"
                    stroke-linecap="round"
                    stroke-dasharray={ringCircum}
                    stroke-dashoffset={ringCircum}
                    data-offset={r.offset}
                    transform="rotate(-90 50 50)"
                    style={`filter:url(#glow-${r.def.id})`}
                  />
                  <circle class="ring-dot" cx={r.endX} cy={r.endY} r="4" fill="#fff" opacity="0" />
                  <text class="ring-number" x="50" y="56" text-anchor="middle" fill="#fff" font-size="18" font-weight="700" font-family="Outfit, sans-serif">
                    <tspan class="ring-counter" data-target={r.level}>0</tspan>
                  </text>
                </svg>
                <span class="ring-name">{r.short} · {r.level}%</span>
              </div>
            ))}
          </div>
        </div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">语言能力</h3>
          <div class="tag-list">
            {profile.languages.map(l => <span class="glass-tag">{l}</span>)}
          </div>
        </div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">兴趣爱好</h3>
          <div class="tag-list">
            {profile.hobbies.slice(0, 5).map(h => <span class="glass-tag">{h}</span>)}
          </div>
        </div>
      </aside>

      <div class="main-col" data-reveal style="--reveal-delay:.08s">
        <div class="stats-row">
          {profile.stats.map((s, i) => (
            <div class="stat-card" data-reveal style={`--reveal-delay:${0.03 * i}s`}>
              <div class="stat-value">{s.value}</div>
              <div class="stat-label">{s.label}</div>
            </div>
          ))}
        </div>

        <section class="resume-section">
          <h2 class="section-title">工作经历</h2>
          <div class="card-list">
            {profile.experience.map(exp => (
              <article class="resume-card">
                <div class="resume-card-head">
                  <h3 class="resume-card-title">{exp.role} · {exp.company}</h3>
                  <span class="resume-card-meta">{exp.period} · {exp.location}</span>
                </div>
                <ul class="resume-highlights">
                  {exp.highlights.map(h => <li>{h}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">项目经验</h2>
          <div class="card-list">
            {profile.projects.map(p => (
              <article class="resume-card">
                <div class="resume-card-head">
                  <h3 class="resume-card-title">{p.name}</h3>
                  <span class="resume-card-meta">{p.role} · {p.period}</span>
                </div>
                <p class="resume-card-desc">{p.description}</p>
                <div class="tech-chips">
                  {p.tech.map(t => <span class="tech-chip">{t}</span>)}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">教育背景</h2>
          <div class="card-list">
            {profile.education.map(e => (
              <article class="resume-card">
                <div class="resume-card-head">
                  <h3 class="resume-card-title">{e.degree} · {e.school}</h3>
                  <span class="resume-card-meta">{e.period}</span>
                </div>
                {e.detail && <p class="resume-card-desc">{e.detail}</p>}
              </article>
            ))}
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">专业技能</h2>
          <div class="resume-card">
            <div class="skill-bars">
              {profile.coreSkills.map((s, i) => (
                <div class="skill-bar">
                  <div class="skill-bar-top">
                    <span class="skill-bar-name">{s.short}</span>
                    <span class="skill-bar-level">{s.level}%</span>
                  </div>
                  <div class="skill-bar-track">
                    <div class="skill-bar-fill" style={`width:${s.level}%; background:${ringDefs[i % ringDefs.length].to}`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">证书荣誉</h2>
          <div class="resume-card">
            <ul class="cert-list">
              {profile.certificates.map(c => (
                <li>
                  <div class="cert-name">{c.name}</div>
                  <div class="cert-meta">{c.issuer} · {c.date}</div>
                </li>
              ))}
            </ul>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  (function () {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    function countUp(el, target, duration = 1200) {
      const start = performance.now();
      function step(now) {
        const p = Math.min((now - start) / duration, 1);
        el.textContent = Math.round(easeOutCubic(p) * target);
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function drawRings(container) {
      container.querySelectorAll('.ring-arc').forEach((arc, idx) => {
        const target = parseFloat(arc.dataset.offset);
        arc.style.transitionDelay = `${idx * 0.12}s`;
        arc.style.strokeDashoffset = String(target);
      });
      container.querySelectorAll('.ring-dot').forEach((dot, idx) => {
        dot.style.transitionDelay = `${0.4 + idx * 0.12}s`;
        dot.style.opacity = '1';
      });
      container.querySelectorAll('.ring-counter').forEach((num) => {
        const target = parseInt(num.dataset.target, 10);
        countUp(num, target);
      });
    }

    const rings = document.querySelectorAll('[data-ring]');
    if (!rings.length) return;

    if (reduced) {
      rings.forEach((wrap) => drawRings(wrap));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          drawRings(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    rings.forEach((wrap) => observer.observe(wrap));
  })();
</script>

<style>
  /* ===== 固定极光背景层 ===== */
  .ambient {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    background-color: var(--color-bg);
  }
  .ambient-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.5;
    animation: blobFloat 18s ease-in-out infinite;
  }
  .blob-1 {
    width: 36vw; height: 36vw;
    top: -8vw; left: -6vw;
    background: radial-gradient(circle, var(--aurora-1) 0%, transparent 70%);
    animation-delay: 0s;
  }
  .blob-2 {
    width: 30vw; height: 30vw;
    top: 10vw; right: -8vw;
    background: radial-gradient(circle, var(--aurora-2) 0%, transparent 70%);
    animation-delay: -4s;
  }
  .blob-3 {
    width: 32vw; height: 32vw;
    bottom: -10vw; left: 20vw;
    background: radial-gradient(circle, var(--aurora-3) 0%, transparent 70%);
    animation-delay: -8s;
  }
  .blob-4 {
    width: 26vw; height: 26vw;
    bottom: 6vw; right: 14vw;
    background: radial-gradient(circle, var(--aurora-4) 0%, transparent 70%);
    animation-delay: -12s;
  }
  .ambient-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(currentColor 1px, transparent 1.6px);
    background-size: 24px 24px;
    color: rgba(99, 102, 241, 0.06);
    opacity: 0.6;
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #1e1b4b 0%, #7c3aed 50%, #ec4899 100%);
    color: #fff;
    padding: 100px 0 84px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.12) 0%, transparent 35%),
      radial-gradient(circle at 80% 70%, rgba(255,255,255,0.10) 0%, transparent 35%);
    opacity: 0.6;
  }
  .hero-aurora {
    position: absolute;
    inset: -30%;
    background: conic-gradient(from 0deg,
      rgba(99,102,241,0.18),
      rgba(236,72,153,0.16),
      rgba(6,182,212,0.16),
      rgba(139,92,246,0.18),
      rgba(99,102,241,0.18));
    filter: blur(60px);
    opacity: 0.55;
    animation: auroraRotate 22s linear infinite;
    mix-blend-mode: screen;
  }
  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  .hero-text { max-width: 600px; }
  .hero-name {
    font-size: 4rem;
    font-weight: 800;
    margin: 0 0 0.2em;
    letter-spacing: -0.03em;
  }
  .hero-title {
    font-size: 1.35rem;
    font-weight: 500;
    color: rgba(255,255,255,0.88);
    margin: 0 0 0.8em;
  }
  .hero-tagline {
    font-size: 1.08rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 0 1.8em;
  }
  .hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-cta .btn {
    border-radius: 14px;
  }
  .hero-cta .btn-primary {
    background: #fff;
    color: #1e1b4b;
    box-shadow: 0 8px 28px rgba(0,0,0,0.25);
  }
  .hero-cta .btn-primary:hover {
    color: #1e1b4b;
    box-shadow: 0 12px 36px rgba(0,0,0,0.32);
  }
  .hero-cta .btn-ghost {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.25);
    color: #fff;
  }
  .hero-cta .btn-ghost:hover {
    background: rgba(255,255,255,0.2);
    color: #fff;
    border-color: rgba(255,255,255,0.35);
  }
  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .visual-3d {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.22);
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 3.2rem;
    font-weight: 800;
    color: rgba(255,255,255,0.9);
    animation: float 5s ease-in-out infinite;
  }
  .code-card {
    width: 100%;
    max-width: 420px;
    border-radius: 16px;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.22);
    padding: 18px 22px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .code-card pre {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.92);
    overflow-x: auto;
  }

  /* ===== Resume Body ===== */
  .resume-body {
    background: transparent;
    padding: 56px 0 80px;
  }
  .resume-inner {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 32px;
    align-items: start;
  }
  .sidebar {
    position: sticky;
    top: 88px;
    max-height: calc(100vh - 104px);
    overflow-y: auto;
    scrollbar-width: thin;
    border-radius: 24px;
    padding: 32px 28px;
    background: linear-gradient(160deg, #1e1b4b 0%, #312e81 60%, #4c1d95 100%);
    color: #fff;
    box-shadow: 0 20px 60px -20px rgba(0,0,0,0.25);
    overflow-x: clip;
  }
  .sidebar-glow {
    position: absolute;
    inset: -40%;
    pointer-events: none;
    background:
      radial-gradient(circle at 20% 20%, rgba(236,72,153,0.22) 0%, transparent 40%),
      radial-gradient(circle at 85% 75%, rgba(124,58,237,0.20) 0%, transparent 40%);
    animation: glowShift 12s ease-in-out infinite alternate;
    z-index: 0;
  }
  .sidebar > * {
    position: relative;
    z-index: 1;
  }
  .avatar-wrap {
    position: relative;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
  }
  .avatar-halo {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, #ec4899, #8b5cf6, #06b6d4, #ec4899);
    animation: haloSpin 6s linear infinite;
    z-index: -1;
    opacity: 0.9;
  }
  .avatar-halo::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    position: relative;
    z-index: 1;
  }
  .avatar-fallback {
    position: absolute;
    inset: 0;
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #ec4899 0%, #8b5cf6 100%);
    z-index: 2;
  }
  .sidebar-name {
    font-size: 1.65rem;
    font-weight: 700;
    margin: 0 0 0.15em;
    color: #fff;
  }
  .sidebar-title {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.72);
    margin: 0 0 1.2em;
    line-height: 1.5;
  }
  .sidebar-divider {
    height: 1px;
    background: rgba(255,255,255,0.18);
    margin: 0 0 22px;
  }
  .sidebar-section { margin-bottom: 24px; }
  .sidebar-section:last-child { margin-bottom: 0; }
  .sidebar-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a5b4fc;
    margin: 0 0 12px;
  }
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .contact-list li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .contact-label { font-size: 0.72rem; color: rgba(255,255,255,0.55); }
  .contact-value { font-size: 0.85rem; color: rgba(255,255,255,0.92); }
  .contact-list a:hover { color: #fff; }

  .skill-rings {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .ring-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ring-wrap:hover {
    transform: translateY(-4px) scale(1.04);
  }
  .ring-svg {
    display: block;
    overflow: visible;
    filter: drop-shadow(0 6px 16px rgba(236, 72, 153, 0.22));
    transition: filter 0.35s ease;
  }
  .ring-wrap:hover .ring-svg {
    filter: drop-shadow(0 10px 28px rgba(236, 72, 153, 0.35));
  }
  .ring-track { transition: stroke 0.3s ease; }
  .ring-arc {
    transition: stroke-dashoffset 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ring-dot {
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: center;
    transform: scale(0);
  }
  .ring-wrap.is-drawn .ring-dot,
  .ring-wrap:hover .ring-dot {
    transform: scale(1);
  }
  .ring-number {
    pointer-events: none;
    text-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }
  .ring-name { font-size: 0.8rem; color: rgba(255,255,255,0.85); }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .glass-tag {
    font-size: 0.82rem;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.18);
    transition: background 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
  }
  .glass-tag:hover {
    background: rgba(255,255,255,0.22);
    border-color: rgba(255,255,255,0.35);
    transform: translateY(-2px);
  }

  /* ===== Main column ===== */
  .main-col { display: flex; flex-direction: column; gap: 32px; }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .stat-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 20px 16px;
    text-align: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }
  .stat-value {
    font-size: 1.9rem;
