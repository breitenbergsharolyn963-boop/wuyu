---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';

const ringColors = ['#ec4899', '#8b5cf6', '#06b6d4', '#6366f1'];
const ringRadius = 40;
const ringCircum = 2 * Math.PI * ringRadius;
const topSkills = profile.coreSkills.slice(0, 4);
const base = import.meta.env.BASE_URL;
const nameInitial = profile.name.slice(0, 1);
---

<BaseLayout title="ResumeBlog" description={`${profile.name} · ${profile.title} —— 个人简历与阶段性研究记录`}>
  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-text" data-reveal>
        <h1 class="hero-name">{profile.name}</h1>
        <p class="hero-title">{profile.title}</p>
        <p class="hero-tagline">{profile.tagline}</p>
        <div class="hero-cta">
          <a href={`${base}about`} class="btn btn-primary">查看完整简历</a>
          <a href={`${base}projects`} class="btn btn-ghost">精选项目</a>
        </div>
      </div>
      <div class="hero-visual" data-reveal style="--reveal-delay:.12s">
        <div class="visual-3d" aria-hidden="true">
          <span>3D</span>
        </div>
        <div class="code-card">
          <pre><code>def dem_simulation(particles):
    return powder_flow + contact_mechanics</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Resume Body ===== -->
  <section class="resume-body">
    <div class="container resume-inner">
      <aside class="sidebar" data-reveal>
        <div class="avatar-wrap">
          <img class="avatar-img" src={`${base}${profile.avatar.replace(/^\//, '')}`} alt={`${profile.name} 头像`} width="96" height="96" loading="eager" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid'" />
          <div class="avatar-fallback" aria-hidden="true" style="display:none">{nameInitial}</div>
        </div>
        <h2 class="sidebar-name">{profile.name}</h2>
        <p class="sidebar-title">{profile.title}</p>

        <div class="sidebar-divider"></div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">联系方式</h3>
          <ul class="contact-list">
            {profile.contacts.map(c => (
              <li>
                <span class="contact-label">{c.label}</span>
                {c.href ? (
                  <a href={c.href} class="contact-value">{c.value}</a>
                ) : (
                  <span class="contact-value">{c.value}</span>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">核心技能</h3>
          <div class="skill-rings">
            {topSkills.map((s, i) => {
              const offset = ringCircum - (s.level / 100) * ringCircum;
              return (
                <div class="ring-wrap">
                  <svg width="110" height="110" viewBox="0 0 100 100" aria-hidden="true">
                    <circle cx="50" cy="50" r={ringRadius} fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="8" />
                    <circle cx="50" cy="50" r={ringRadius} fill="none" stroke={ringColors[i % ringColors.length]} stroke-width="8" stroke-linecap="round" stroke-dasharray={ringCircum} stroke-dashoffset={offset} transform="rotate(-90 50 50)" />
                    <text x="50" y="55" text-anchor="middle" fill="#fff" font-size="14" font-weight="700">{s.level}</text>
                  </svg>
                  <span class="ring-name">{s.short}</span>
                </div>
              );
            })}
          </div>
        </div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">语言能力</h3>
          <div class="tag-list">
            {profile.languages.map(l => <span class="glass-tag">{l}</span>)}
          </div>
        </div>

        <div class="sidebar-section">
          <h3 class="sidebar-label">兴趣爱好</h3>
          <div class="tag-list">
            {profile.hobbies.slice(0, 5).map(h => <span class="glass-tag">{h}</span>)}
          </div>
        </div>
      </aside>

      <div class="main-col" data-reveal style="--reveal-delay:.08s">
        <div class="stats-row">
          {profile.stats.map((s, i) => (
            <div class="stat-card" data-reveal style={`--reveal-delay:${0.03 * i}s`}>
              <div class="stat-value">{s.value}</div>
              <div class="stat-label">{s.label}</div>
            </div>
          ))}
        </div>

        <section class="resume-section">
          <h2 class="section-title">工作经历</h2>
          <div class="card-list">
            {profile.experience.map(exp => (
              <article class="resume-card">
                <div class="resume-card-head">
                  <h3 class="resume-card-title">{exp.role} · {exp.company}</h3>
                  <span class="resume-card-meta">{exp.period} · {exp.location}</span>
                </div>
                <ul class="resume-highlights">
                  {exp.highlights.map(h => <li>{h}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">项目经验</h2>
          <div class="card-list">
            {profile.projects.map(p => (
              <article class="resume-card">
                <div class="resume-card-head">
                  <h3 class="resume-card-title">{p.name}</h3>
                  <span class="resume-card-meta">{p.role} · {p.period}</span>
                </div>
                <p class="resume-card-desc">{p.description}</p>
                <div class="tech-chips">
                  {p.tech.map(t => <span class="tech-chip">{t}</span>)}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">教育背景</h2>
          <div class="card-list">
            {profile.education.map(e => (
              <article class="resume-card">
                <div class="resume-card-head">
                  <h3 class="resume-card-title">{e.degree} · {e.school}</h3>
                  <span class="resume-card-meta">{e.period}</span>
                </div>
                {e.detail && <p class="resume-card-desc">{e.detail}</p>}
              </article>
            ))}
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">专业技能</h2>
          <div class="resume-card">
            <div class="skill-bars">
              {profile.coreSkills.map((s, i) => (
                <div class="skill-bar">
                  <div class="skill-bar-top">
                    <span class="skill-bar-name">{s.short}</span>
                    <span class="skill-bar-level">{s.level}%</span>
                  </div>
                  <div class="skill-bar-track">
                    <div class="skill-bar-fill" style={`width:${s.level}%; background:${ringColors[i % ringColors.length]}`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="resume-section">
          <h2 class="section-title">证书荣誉</h2>
          <div class="resume-card">
            <ul class="cert-list">
              {profile.certificates.map(c => (
                <li>
                  <div class="cert-name">{c.name}</div>
                  <div class="cert-meta">{c.issuer} · {c.date}</div>
                </li>
              ))}
            </ul>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #1e1b4b 0%, #7c3aed 50%, #ec4899 100%);
    color: #fff;
    padding: 100px 0 84px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.12) 0%, transparent 35%),
      radial-gradient(circle at 80% 70%, rgba(255,255,255,0.10) 0%, transparent 35%);
    opacity: 0.6;
  }
  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  .hero-text { max-width: 600px; }
  .hero-name {
    font-size: 4rem;
    font-weight: 800;
    margin: 0 0 0.2em;
    letter-spacing: -0.03em;
  }
  .hero-title {
    font-size: 1.35rem;
    font-weight: 500;
    color: rgba(255,255,255,0.88);
    margin: 0 0 0.8em;
  }
  .hero-tagline {
    font-size: 1.08rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 0 1.8em;
  }
  .hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-cta .btn {
    border-radius: 14px;
  }
  .hero-cta .btn-primary {
    background: #fff;
    color: #1e1b4b;
    box-shadow: 0 8px 28px rgba(0,0,0,0.25);
  }
  .hero-cta .btn-primary:hover {
    color: #1e1b4b;
    box-shadow: 0 12px 36px rgba(0,0,0,0.32);
  }
  .hero-cta .btn-ghost {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.25);
    color: #fff;
  }
  .hero-cta .btn-ghost:hover {
    background: rgba(255,255,255,0.2);
    color: #fff;
    border-color: rgba(255,255,255,0.35);
  }
  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .visual-3d {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.22);
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 3.2rem;
    font-weight: 800;
    color: rgba(255,255,255,0.9);
    animation: float 5s ease-in-out infinite;
  }
  .code-card {
    width: 100%;
    max-width: 420px;
    border-radius: 16px;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.22);
    padding: 18px 22px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .code-card pre {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.92);
    overflow-x: auto;
  }

  /* ===== Resume Body ===== */
  .resume-body {
    background: var(--color-bg-subtle);
    padding: 56px 0 80px;
  }
  .resume-inner {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 32px;
    align-items: start;
  }
  .sidebar {
    position: sticky;
    top: 88px;
    border-radius: 24px;
    padding: 32px 28px;
    background: linear-gradient(160deg, #1e1b4b 0%, #312e81 60%, #4c1d95 100%);
    color: #fff;
    box-shadow: 0 20px 60px -20px rgba(0,0,0,0.25);
  }
  .avatar-wrap {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    background: #7c3aed;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .avatar-fallback {
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
  }
  .sidebar-name {
    font-size: 1.65rem;
    font-weight: 700;
    margin: 0 0 0.15em;
    color: #fff;
  }
  .sidebar-title {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.72);
    margin: 0 0 1.2em;
    line-height: 1.5;
  }
  .sidebar-divider {
    height: 1px;
    background: rgba(255,255,255,0.18);
    margin: 0 0 22px;
  }
  .sidebar-section { margin-bottom: 24px; }
  .sidebar-section:last-child { margin-bottom: 0; }
  .sidebar-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a5b4fc;
    margin: 0 0 12px;
  }
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .contact-list li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .contact-label { font-size: 0.72rem; color: rgba(255,255,255,0.55); }
  .contact-value { font-size: 0.85rem; color: rgba(255,255,255,0.92); }
  .contact-list a:hover { color: #fff; }
  .skill-rings {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .ring-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .ring-wrap svg { display: block; }
  .ring-name { font-size: 0.8rem; color: rgba(255,255,255,0.85); }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .glass-tag {
    font-size: 0.82rem;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.18);
  }

  /* ===== Main column ===== */
  .main-col { display: flex; flex-direction: column; gap: 32px; }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .stat-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 20px 16px;
    text-align: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }
  .stat-value {
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin-top: 6px;
  }

  .resume-section { scroll-margin-top: 88px; }
  .section-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0 0 16px;
    color: var(--color-text);
  }
  .section-title::before,
  .section-title::after { content: none; }
  .card-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .resume-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 22px 24px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }
  .resume-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .resume-card-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
    color: var(--color-text);
  }
  .resume-card-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .resume-card-desc {
    font-size: 0.92rem;
    color: var(--color-text-soft);
    margin: 0 0 10px;
    line-height: 1.65;
  }
  .resume-highlights {
    margin: 0;
    padding-left: 1.2em;
    color: var(--color-text-soft);
    font-size: 0.92rem;
    line-height: 1.7;
  }
  .resume-highlights li { margin-bottom: 6px; }
  .resume-highlights li:last-child { margin-bottom: 0; }
  .tech-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  .tech-chip {
    font-size: 0.76rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 6px;
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .skill-bars {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .skill-bar-top {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    margin-bottom: 6px;
    color: var(--color-text);
  }
  .skill-bar-level { color: var(--color-text-muted); font-weight: 500; }
  .skill-bar-track {
    height: 8px;
    border-radius: 4px;
    background: var(--color-bg-subtle);
    overflow: hidden;
  }
  .skill-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cert-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cert-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }
  .cert-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1020px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-text { margin: 0 auto; }
    .hero-cta { justify-content: center; }
    .hero-visual { order: -1; }
    .visual-3d { width: 160px; height: 160px; font-size: 2.2rem; }
    .resume-inner { grid-template-columns: 1fr; }
    .sidebar { position: static; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .hero { padding: 72px 0 56px; }
    .hero-name { font-size: 2.8rem; }
    .hero-title { font-size: 1.1rem; }
    .hero-tagline { font-size: 1rem; }
    .stats-row { grid-template-columns: 1fr 1fr; }
    .resume-card-head { flex-direction: column; gap: 6px; }
    .sidebar { padding: 24px 20px; }
  }
</style>
